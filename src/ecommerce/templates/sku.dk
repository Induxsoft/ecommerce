#include "dkli.dkh"
#!
module "Product page"
{
    ref _db = get_database()
    ref get = @@(@http_context, "&request/get")
    ref product = dbr.rec(_db, "SELECT * FROM producto WHERE sys_pk = @p", get)

    #$ div(class="container-sm p-5 bg-white mt-4")
    {
        div(class="mb-4 d-flex flex-wrap")
        {
            h3(class="m-0 flex-grow-1"){$"Producto"}
        }
        div(class="p-4")
        {
            $"#<to.json(product)>"
        }
    }
}