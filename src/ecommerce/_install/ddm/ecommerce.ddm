#include "ddm.dkh"
model ""
{
    #include "induxsoft.abstracts.ddm"

    entity "tuser"
    {
        @"sys_pk" int key required autoincrement
        @"sys_guid" string(32) unique required
        @"sys_dtcreated" datetime
        @"sys_timestamp" datetime required
        @"sys_info" string(32)
        @"sys_user" string(32)
        @"sys_lastuser" string(32)
        @"sys_exported" bool
        @"sys_dtexported" datetime
        @"sys_recver" int
        @"sys_deleted" bool
        @"sys_lock" int

        @"locked" bool 
        @"message" string(255) 
        @"notes" memo 
        @"pwd" string(32) 
        @"userid" string(120) unique required
        @"username" string(120) required
        @"pwdmd5" string(64) 
        @"external" bool    //Si es true, el usuario se consiera externo
    }

    entity "tuserpro": "TableModel"
    {
        @"ref_user" ref:"tuser" unique required
        @"email" string(255) unique required
        @"mobile" string(15) unique required
    }

    entity "pwd_chg_req"
    {
        @"rcode" string(32)
        @"timestamp" datetime
        @"uid" string(32)
        @"used" datetime
        @"lastsend" datetime
        @"sendcount" int
    }

    entity "pais" : "TableModel"
    {
        @"codigo" string(8) unique required
        @"codigotel" string(5)
        @"nombre" string(100) unique required
    }

    entity "ecom_usr_adr":"TableModel"
    {
        @"ref_user" ref:"tuser" required
        @"label" string(35) required
        @"country" ref: "pais" required
        @"zip" string(15) required
        @"addr_l1" string(512)
        @"addr_l2" string(512)
        @"addr_l3" string(512)
        @"phone" string(50)
        @"recip_name" string(100)
        @"notes" memo
        
        index "ecom_usr_adr_lbl1" unique
        {
            field "ref_user"
            field "label"
        }
    }


    entity "tuser" :"TableModel"{}
    entity "producto" :"TableModel"{}
    entity "venta" :"TableModel"{}
    entity "cliente" :"TableModel"{}

    entity "ecomm_cart_fpago" :"EnumModel"
    {
        /*
        0-Pendiente
        1-On line
        2-A la entrega
        3-Crédito de cliente
        */
    }


    // Estado del carrito
	entity "ecomm_cart_status" :"EnumModel"
    {
        /*
        0-Abierto
        1-Cerrado
        99-Cancelado
        */
    }

	// Forma de entrega de la compra
	entity "ecomm_cart_fentrega" :"EnumModel"
    {
        /*
        0-Envío a domicilio
        1-Pasar a recoger
        99-No se requiere entrega física
        */
    }
	
    entity "ecomm_cart" : "TableModel"
    {
		@"tienda" string(32) // Un identificador usado para distinguir carritos de varias tiendas 
        @"ref_user" ref:"tuser"
        @"ref_cliente" ref:"cliente"
        @"status" ref:"ecomm_cart_status" required
        @"pedido" ref:"venta" unique
        @"fpago" ref: "ecomm_cart_fpago"
		@"entrega" ref:"ecomm_cart_fentrega" 
		@"enviara" ref: "ecom_usr_adr" //La dirección de envío del usuario (si hay productos que enviar)
		@"id_pago" string(32) //Una referencia a la transacción de pago
    }

    entity "ecomm_cart_det" : "TableModel"
    {
        @"ref_cart" ref:"ecomm_cart" required
        @"ref_prdo" ref:"producto" required
        @"cantidad" decimal(12,4) required
        @"unidad" string(15) required
        @"precio" decimal(12,4) required
        @"numprecio" int required // Número de precio que se usó, cero si no corresponde a ninguno de los 20 del catálogo de productos
        @"descuento1" decimal(12,4)
		@"descuento2" decimal(12,4)
        @"impuesto1" decimal(12,4)
		@"impuesto2" decimal(12,4)
		@"impuesto3" decimal(12,4)
		@"impuesto4" decimal(12,4)
        @"notas" memo
        @"cupon" string(45) // Código de descuento aplicado
    }
}